# OpenAI API Key
OPENAI_API_KEY=sk-your-api-key-here

# Model Configuration
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Redis Configuration (optional - uses fakeredis by default)
REDIS_URL=redis://localhost:6379

# Context Window
MAX_CONTEXT_TOKENS=8192
TRIM_THRESHOLD=0.8

# Memory Settings
BUFFER_MEMORY_MAX_MESSAGES=20
EPISODIC_LOG_DIR=data/episodic_logs
CHROMA_DB_DIR=data/chroma_db
